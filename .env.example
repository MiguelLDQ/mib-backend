SERVER_PORT=8080

DATABASE_URL=jdbc:postgresql://localhost:5432/mib
DATABASE_USERNAME=mib_user
DATABASE_PASSWORD=mib_password

# Gere um valor forte, ex: openssl rand -base64 64
JWT_SECRET=change-this-secret-in-production-min-256-bits-please-replace-me
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# IA de apoio emocional (Fase 13) - Groq (https://console.groq.com), gratuito
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

LOG_LEVEL=INFO
